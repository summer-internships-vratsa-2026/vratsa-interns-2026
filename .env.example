# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Local (Docker): postgresql://core_lms:core_lms@localhost:5432/core_lms
# Production (Neon): use your Neon connection string
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
DATABASE_URL=postgresql://core_lms:core_lms@localhost:5432/core_lms

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Email (Resend) — https://resend.com
# 1. Create an API key in the Resend dashboard
# 2. For quick testing without a custom domain, use:
#      RESEND_FROM_EMAIL=onboarding@resend.dev
#    (Resend only delivers to the email you signed up with)
# 3. For production, verify your domain in Resend and use e.g.:
#      RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Vratsa Software

# Seed (local dev)
SEED_ADMIN_EMAIL=emo@vratsasoftware.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
